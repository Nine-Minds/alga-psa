{
  "cli": {
    "version": ">= 8.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_PHASE2_NOTIFICATIONS": "true"
      }
    },
    "testflight": {
      "ios": {
        "distribution": "store"
      }
    },
    "playInternal": {
      "android": {
        "distribution": "store"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "ascAppId": "6760326836"
      }
    },
    "playInternal": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed",
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    }
  }
}
