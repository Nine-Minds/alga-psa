{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nine-Minds/alga-psa/ee/appliance/releases/schema.json",
  "title": "Alga Appliance Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "releaseVersion",
    "generatedAt",
    "app"
  ],
  "properties": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?(-[A-Za-z0-9._-]+)?$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "releaseBranch", "valuesProfile", "images"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "releaseBranch": {
          "type": "string",
          "pattern": "^release/.+$"
        },
        "valuesProfile": {
          "type": "string",
          "minLength": 1
        },
        "images": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algaCore", "workflowWorker", "emailService", "temporalWorker"],
          "properties": {
            "algaCore": {
              "type": "string",
              "minLength": 1
            },
            "workflowWorker": {
              "type": "string",
              "minLength": 1
            },
            "emailService": {
              "type": "string",
              "minLength": 1
            },
            "temporalWorker": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
