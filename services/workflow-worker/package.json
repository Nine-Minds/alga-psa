    "@eslint/plugin-kit": "0.3.5",
    "@js-temporal/polyfill": "^0.4.4",
    "@temporalio/worker": "~1.14.1",
    "@temporalio/workflow": "~1.14.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.16.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.3",
    "knex": "^3.1.0",
    "node-vault": "^0.10.2",
    "pg": "8.12.0",
    "redis": "4.7.0",
