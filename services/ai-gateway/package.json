{
  "name": "ai-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "AI metering, credit ledger, and provider gateway service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "test": "vitest run",
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/integration"
  },
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.3",
    "knex": "^3.1.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.24",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
