{
  "name": "@alga-psa/assets",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/assets/src",
  "projectType": "library",
  "tags": ["scope:assets", "type:vertical"],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/assets/**/*.{ts,tsx}"]
      }
    }
  }
}
