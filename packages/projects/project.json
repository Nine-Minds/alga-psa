{
  "name": "@alga-psa/projects",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/projects/src",
  "projectType": "library",
  "tags": [
    "scope:projects",
    "type:vertical"
  ],
  "targets": {
    "build": {
      "executor": "nx:noop"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/projects/**/*.{ts,tsx}"
        ]
      }
    }
  }
}
