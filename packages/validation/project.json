{
  "name": "@alga-psa/validation",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/validation/src",
  "projectType": "library",
  "tags": [
    "scope:validation",
    "type:horizontal"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build",
        "cwd": "packages/validation"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/validation/**/*.{ts,tsx}"
        ]
      }
    }
  }
}
