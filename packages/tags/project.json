{
  "name": "@alga-psa/tags",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/tags/src",
  "projectType": "library",
  "tags": [
    "scope:tags",
    "type:horizontal"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/tags/**/*.{ts,tsx}"
        ]
      }
    }
  }
}
