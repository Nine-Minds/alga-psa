{
  "name": "@alga-psa/sla",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js",
      "require": "./dist/actions/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js",
      "require": "./dist/services/index.js"
    },
    "./services/slaNotificationService": {
      "types": "./dist/services/slaNotificationService.d.ts",
      "import": "./dist/services/slaNotificationService.js",
      "require": "./dist/services/slaNotificationService.js"
    },
    "./services/backends": {
      "types": "./dist/services/backends/index.d.ts",
      "import": "./dist/services/backends/index.js",
      "require": "./dist/services/backends/index.js"
    },
    "./services/itilSlaService": {
      "types": "./dist/services/itilSlaService.d.ts",
      "import": "./dist/services/itilSlaService.js",
      "require": "./dist/services/itilSlaService.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@alga-psa/auth": "*",
    "@alga-psa/core": "*",
    "@alga-psa/db": "*",
    "@alga-psa/notifications": "*",
    "@alga-psa/reference-data": "*",
    "@alga-psa/shared": "*",
    "@alga-psa/types": "*",
    "@alga-psa/ui": "*",
    "@alga-psa/user-composition": "*",
    "lucide-react": "^0.454.0",
    "react-hot-toast": "^2.4.1",
    "date-fns-tz": "^3.2.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
