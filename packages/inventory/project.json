{
  "name": "@alga-psa/inventory",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/inventory/src",
  "projectType": "library",
  "tags": ["scope:inventory", "type:vertical"],
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/inventory"],
      "options": {
        "configFile": "packages/inventory/vitest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/inventory/**/*.{ts,tsx}"]
      }
    }
  }
}
