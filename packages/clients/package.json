{
  "name": "@alga-psa/clients",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./actions": {
      "types": "./src/actions/index.ts",
      "import": "./dist/actions/index.js",
      "require": "./dist/actions/index.js"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.js"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "import": "./dist/models/index.js",
      "require": "./dist/models/index.js"
    },
    "./context/ClientCrossFeatureContext": {
      "types": "./src/context/ClientCrossFeatureContext.tsx",
      "import": "./dist/context/ClientCrossFeatureContext.js",
      "require": "./dist/context/ClientCrossFeatureContext.js"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.js"
    },
    "./providers/*": {
      "import": "./src/providers/*.tsx",
      "types": "./src/providers/*.tsx"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alga-psa/block-content": "*",
    "@alga-psa/core": "*",
    "@alga-psa/db": "*",
    "@alga-psa/formatting": "*",
    "@alga-psa/shared": "*",
    "@alga-psa/storage": "*",
    "@alga-psa/types": "*",
    "@alga-psa/ui": "*",
    "@alga-psa/user-composition": "*",
    "@alga-psa/validation": "*",
    "@alga-psa/workflow-streams": "*",
    "@alga-psa/workflows": "*",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0"
  }
}
