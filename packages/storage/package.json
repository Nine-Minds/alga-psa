{
  "name": "@alga-psa/storage",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./src/index.ts"
    },
    "./StorageService": {
      "import": "./dist/StorageService.mjs",
      "types": "./src/StorageService.ts"
    },
    "./StorageProviderFactory": {
      "import": "./dist/StorageProviderFactory.mjs",
      "types": "./src/StorageProviderFactory.ts"
    },
    "./types/storage": {
      "import": "./dist/types/storage.mjs",
      "types": "./src/types/storage.ts"
    },
    "./providers/StorageProvider": {
      "import": "./dist/providers/StorageProvider.mjs",
      "types": "./src/providers/StorageProvider.ts"
    },
    "./config/storage": {
      "import": "./dist/config/storage.mjs",
      "types": "./src/config/storage.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@alga-psa/core": "*",
    "@alga-psa/db": "*",
    "@alga-psa/event-bus": "*",
    "@alga-psa/formatting": "*",
    "@alga-psa/validation": "*",
    "file-type": "^21.3.2"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
