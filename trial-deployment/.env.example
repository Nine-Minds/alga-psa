# Trial Deployment Configuration
# ================================

# Base domain for trial instances. Each trial gets a subdomain: <id>.<base-domain>
TRIAL_BASE_DOMAIN=trials.alga-psa.com

# Path to the Helm chart (relative to this app, or absolute)
TRIAL_HELM_CHART_PATH=../helm

# Docker images for the deployed Alga PSA instances
TRIAL_SERVER_IMAGE=ghcr.io/nine-minds/alga-psa-ce
TRIAL_SERVER_IMAGE_TAG=latest
TRIAL_SETUP_IMAGE=ghcr.io/nine-minds/alga-psa-ce
TRIAL_SETUP_IMAGE_TAG=latest

# Trial duration in hours before automatic cleanup
TRIAL_DURATION_HOURS=72

# Kubernetes context (leave empty to use current/in-cluster context)
TRIAL_KUBE_CONTEXT=

# Kubernetes storage class for PVCs
TRIAL_STORAGE_CLASS=local-path

# Whether Istio is enabled in the target cluster
TRIAL_ISTIO_ENABLED=false

# Path to kubeconfig (leave empty for in-cluster auth)
KUBECONFIG=
